{
  "name": "kqa-desktop",
  "version": "2.0.1",
  "description": "KQA - Gerador de Dados para QA (App Desktop)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:patch": "npm version patch -m \"Release v%s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"Release v%s\" && git push && git push --tags",
    "release:major": "npm version major -m \"Release v%s\" && git push && git push --tags"
  },
  "build": {
    "appId": "com.kqa.desktop",
    "productName": "KQA Desktop",
    "copyright": "Sistema KQA",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KQA Desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DantexgerBR",
        "repo": "KQA-desktop"
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  }
}
